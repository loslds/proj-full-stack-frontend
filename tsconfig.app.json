
{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,

    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["vite/client"],

    "ignoreDeprecations": "5.0"
  },
  "include": ["src"]
}

